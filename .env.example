# ─── CTS ETS ENVIRONMENT VARIABLES ───────────────────────────────────
# Copy this file to .env and fill in your real values.
# NEVER commit .env to Git — only this .env.example file.

# Google Apps Script backend
VITE_APPS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# EmailJS
VITE_EMAILJS_KEY=your_emailjs_public_key
VITE_EMAILJS_SERVICE=your_emailjs_service_id
VITE_EMAILJS_TEMPLATE=your_emailjs_template_id

# WiPay
VITE_WIPAY_ACCOUNT=your_wipay_account_number
VITE_WIPAY_KEY=your_wipay_api_key

# Brevo (Sendinblue) email
VITE_BREVO_KEY=your_brevo_api_key
